---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
const posts = (await getCollection('blog')).sort(
	(a, b) => (b.data.pubDate ?? b.data.date ?? new Date()).valueOf() - (a.data.pubDate ?? a.data.date ?? new Date()).valueOf(),
);
---
<!doctype html>
<html lang="it">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main { width: 1000px; }
			.blog-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2.5rem 2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.blog-grid li:first-child {
				grid-column: 1 / -1;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
				align-items: center;
				padding-bottom: 2.5rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 1rem;
			}
			.blog-grid li:first-child .title {
				font-size: 2.2rem;
			}
			.blog-grid li:first-child .meta {
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 1rem;
			}
			article a {
				display: block;
				text-decoration: none;
				border-bottom: none;
			}
			.title {
				font-family: 'Playfair Display', Georgia, serif;
				font-size: 1.1rem;
				font-weight: 700;
				color: rgb(var(--black));
				line-height: 1.3;
				margin: 0.4rem 0 0.3rem;
				transition: color 0.2s ease;
			}
			.date {
				font-family: 'Montserrat', sans-serif;
				font-size: 0.72rem;
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--accent);
				margin: 0;
			}
			article a:hover .title {
				color: var(--accent);
			}
			.category-tag {
				display: inline-block;
				font-family: 'Montserrat', sans-serif;
				font-size: 0.65rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: white;
				background: var(--accent-red);
				padding: 2px 8px;
				border-radius: 2px;
				margin-bottom: 0.5rem;
			}
			.divider {
				border: none;
				border-top: 1px solid rgb(var(--gray-light));
				margin: 0 0 2.5rem;
			}
			@media (max-width: 720px) {
				.blog-grid { grid-template-columns: 1fr; }
				.blog-grid li:first-child {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<hr class="divider" />
			<ul class="blog-grid">
				{posts.map((post, index) => (
					<li>
						<article>
							<a href={`/blog/${post.id}/`}>
								{post.data.categories && post.data.categories[0] && (
									<span class="category-tag">{post.data.categories[0]}</span>
								)}
								<h2 class="title">{post.data.title}</h2>
								<p class="date">
									<FormattedDate date={post.data.pubDate ?? post.data.date ?? new Date()} />
								</p>
							</a>
						</article>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
